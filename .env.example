# --- Core services ---
DATABASE_URL=postgresql+asyncpg://compliance:compliance@postgres:5432/compliance
SYNC_DATABASE_URL=postgresql+psycopg2://compliance:compliance@postgres:5432/compliance
REDIS_URL=redis://redis:6379/0
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# --- LLM / embeddings ---
LLM_PROVIDER=nvidia               # nvidia | anthropic | openai
NVIDIA_API_KEY=nvapi-your-new-key-here
CHAT_MODEL=nvidia/nemotron-3-ultra-550b-a55b
REASONING_BUDGET=8192
ENABLE_THINKING=true
EMBEDDING_MODEL=nvidia/nemotron-3-embed-8b
# --- Auth ---
API_KEY=change-me-strong-api-key

# --- MCP agent layer ---
SLACK_MCP_TOKEN=xoxb-your-slack-token
SLACK_CHANNEL=#compliance-alerts
SEC_EDGAR_USER_AGENT=FinSci Compliance Auditor admin@example.com

# --- Misc ---
LOG_LEVEL=INFO
