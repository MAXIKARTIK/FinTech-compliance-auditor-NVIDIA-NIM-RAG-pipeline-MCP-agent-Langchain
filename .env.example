# ===== Core services (Docker Compose network names) =====
DATABASE_URL=postgresql+asyncpg://compliance:compliance@postgres:5432/compliance
SYNC_DATABASE_URL=postgresql+psycopg2://compliance:compliance@postgres:5432/compliance
REDIS_URL=redis://redis:6379/0
CHROMA_HOST=chromadb
CHROMA_PORT=8000

# ===== LLM / embeddings (NVIDIA NIM) =====
LLM_PROVIDER=nvidia               # nvidia | anthropic | openai
NVIDIA_API_KEY=nvapi-your-new-key-here
# OPENAI_API_KEY=sk-...           # only needed when LLM_PROVIDER=openai
# ANTHROPIC_API_KEY=sk-ant-...    # only needed when LLM_PROVIDER=anthropic
CHAT_MODEL=nvidia/nemotron-3-ultra-550b-a55b
REASONING_BUDGET=8192
ENABLE_THINKING=true
CHAT_TEMPERATURE=0.0              # keep 0 for reproducible scoring
CHAT_TOP_P=1.0
EMBEDDING_MODEL=nvidia/nemotron-3-embed-1b
EMBED_DIM=2048

# ===== Audit reproducibility =====
# Reuse a prior verdict when the same filing content is re-audited with the same
# rule version + model params, so identical re-runs score identically.
AUDIT_REUSE_FINDINGS=true

# ===== Auth =====
API_KEY=change-me-strong-api-key

# ===== CORS =====
# Comma-separated browser origins allowed to call the API.
# Local dev: http://localhost:5173  |  Prod: your deployed dashboard URL.
# Use "*" to allow any origin (handy for a public demo).
CORS_ORIGINS=http://localhost:5173

# ===== MCP agent layer =====
SLACK_MCP_TOKEN=xoxb-your-slack-token
SLACK_CHANNEL=#compliance-alerts
SEC_EDGAR_USER_AGENT=FinSci Compliance Auditor admin@example.com

# ===== Misc =====
LOG_LEVEL=INFO
UPLOAD_DIR=/data/uploads

# ===== Optional: free stable hostname (DuckDNS) for AWS EC2 stop/start =====
# From https://www.duckdns.org — lets you skip a paid Elastic IP.
# Enable with: DUCKDNS=1 ./deploy/deploy.sh
DUCKDNS_SUBDOMAIN=
DUCKDNS_TOKEN=
